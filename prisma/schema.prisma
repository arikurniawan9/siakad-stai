generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  admin
  bendahara
  dosen
  mahasiswa
}

model Profile {
  id           String    @id @db.Uuid
  email        String    @unique
  role         UserRole  @default(mahasiswa)
  nama_lengkap String?
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  updated_at   DateTime  @default(now()) @db.Timestamptz(6)
  
  mahasiswa    Mahasiswa?
  dosen        Dosen?

  @@map("profiles")
}

model Settings {
  id              Int      @id @default(1)
  school_name     String?  @default("SIAKAD UNIVERSITAS")
  school_logo_url String?  @default("/Wikimedia-logo.png")
  updated_at      DateTime @default(now()) @db.Timestamptz(6)

  @@map("settings")
}

model ProgramStudi {
  id          BigInt      @id @default(autoincrement())
  nama_prodi  String
  kode_prodi  String      @unique
  fakultas    String?
  created_at  DateTime    @default(now()) @db.Timestamptz(6)
  
  mahasiswa   Mahasiswa[]

  @@map("program_studi")
}

model Dosen {
  id           String   @id @db.Uuid
  nidn         String?  @unique
  nama_lengkap String
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  
  profile      Profile  @relation(fields: [id], references: [id], onDelete: Cascade)

  @@map("dosen")
}

model Mahasiswa {
  id           String       @id @db.Uuid
  nim          String       @unique
  prodi_id     BigInt
  angkatan     Int
  status_aktif Boolean      @default(true)
  created_at   DateTime     @default(now()) @db.Timestamptz(6)
  
  profile      Profile      @relation(fields: [id], references: [id], onDelete: Cascade)
  program_studi ProgramStudi @relation(fields: [prodi_id], references: [id])

  @@map("mahasiswa")
}
